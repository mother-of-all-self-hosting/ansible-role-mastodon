[Unit]
Description=Mastodon streaming API server ({{ mastodon_streaming_identifier }})
{% for service in mastodon_streaming_systemd_required_services_list %}
Requires={{ service }}
After={{ service }}
{% endfor %}
{% for service in mastodon_streaming_systemd_wanted_services_list %}
Wants={{ service }}
{% endfor %}
DefaultDependencies=no

[Service]
Type=simple
Environment="HOME={{ devture_systemd_docker_base_systemd_unit_home_path }}"
ExecStartPre={{ devture_systemd_docker_base_host_command_sh }} -c '{{ mastodon_streaming_container_cleanup_command | trim | replace("\n", " ") }}'

{#
  Running as root is necessary to avoid the error:
  "Error: Cannot find module '/opt/mastodon/streaming/index.js'"
#}
ExecStartPre={{ devture_systemd_docker_base_host_command_docker }} create \
      --rm \
      --name={{ mastodon_streaming_identifier }} \
      --log-driver=none \
      --user=0:0 \
      --network={{ mastodon_streaming_container_network }} \
      {% if mastodon_streaming_container_http_host_bind_port %}
      -p {{ mastodon_streaming_container_http_host_bind_port }}:{{ mastodon_streaming_container_http_port }} \
      {% endif %}
      --env-file={{ mastodon_base_path }}/env \
      --label-file={{ mastodon_streaming_base_path }}/labels \
      {% for volume in mastodon_streaming_container_additional_volumes %}
      --mount type={{ volume.type | default('bind' if '/' in volume.src else 'volume') }},src={{ volume.src }},dst={{ volume.dst }}{{ (',' + volume.options) if volume.options | default('') else '' }} \
      {% endfor %}
      {% for arg in mastodon_streaming_container_extra_arguments %}
      {{ arg }} \
      {% endfor %}
      {{ mastodon_streaming_container_image }} \
      node ./streaming/index.js

{% for network in mastodon_streaming_container_additional_networks %}
ExecStartPre={{ devture_systemd_docker_base_host_command_docker }} network connect {{ network }} {{ mastodon_streaming_identifier }}
{% endfor %}

ExecStart={{ devture_systemd_docker_base_host_command_docker }} start --attach {{ mastodon_streaming_identifier }}

ExecStop=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} stop -t {{ devture_systemd_docker_base_container_stop_grace_time_seconds }} {{ mastodon_streaming_identifier }} 2>/dev/null || true'
ExecStop=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} rm {{ mastodon_streaming_identifier }} 2>/dev/null || true'

Restart=always
RestartSec=30
SyslogIdentifier={{ mastodon_streaming_identifier }}

[Install]
WantedBy=multi-user.target
