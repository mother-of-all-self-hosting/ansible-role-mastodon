[Unit]
Description=Mastodon web ({{ mastodon_web_identifier }})
{% for service in mastodon_web_systemd_required_services_list %}
Requires={{ service }}
After={{ service }}
{% endfor %}
{% for service in mastodon_web_systemd_wanted_services_list %}
Wants={{ service }}
{% endfor %}
DefaultDependencies=no

[Service]
Type=simple
Environment="HOME={{ devture_systemd_docker_base_systemd_unit_home_path }}"
ExecStartPre=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} stop -t {{ devture_systemd_docker_base_container_stop_grace_time_seconds }} {{ mastodon_web_identifier }} 2>/dev/null || true'
ExecStartPre=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} rm {{ mastodon_web_identifier }} 2>/dev/null || true'

ExecStartPre={{ devture_systemd_docker_base_host_command_docker }} create \
      --rm \
      --name={{ mastodon_web_identifier }} \
      --log-driver=none \
      --user={{ mastodon_uid }}:{{ mastodon_gid }} \
      --cap-drop=ALL \
      --read-only \
      --network={{ mastodon_web_container_network }} \
      {% if mastodon_web_container_http_host_bind_port %}
      -p {{ mastodon_web_container_http_host_bind_port }}:{{ mastodon_web_container_http_port }} \
      {% endif %}
      --env-file={{ mastodon_base_path }}/env \
      --label-file={{ mastodon_web_base_path }}/labels \
      --mount type=bind,src={{ mastodon_data_path }},dst=/mastodon/public/system \
      {% for volume in mastodon_web_container_additional_volumes %}
      --mount type={{ volume.type | default('bind' if '/' in volume.src else 'volume') }},src={{ volume.src }},dst={{ volume.dst }}{{ (',' + volume.options) if volume.options else '' }} \
      {% endfor %}
      {% for arg in mastodon_web_container_extra_arguments %}
      {{ arg }} \
      {% endfor %}
      {{ mastodon_web_container_image }} \
      bundle exec puma -C config/puma.rb

{% for network in mastodon_web_container_additional_networks %}
ExecStartPre={{ devture_systemd_docker_base_host_command_docker }} network connect {{ network }} {{ mastodon_web_identifier }}
{% endfor %}

ExecStart={{ devture_systemd_docker_base_host_command_docker }} start --attach {{ mastodon_web_identifier }}

ExecStop=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} stop -t {{ devture_systemd_docker_base_container_stop_grace_time_seconds }} {{ mastodon_web_identifier }} 2>/dev/null || true'
ExecStop=-{{ devture_systemd_docker_base_host_command_sh }} -c '{{ devture_systemd_docker_base_host_command_docker }} rm {{ mastodon_web_identifier }} 2>/dev/null || true'

Restart=always
RestartSec=30
SyslogIdentifier={{ mastodon_web_identifier }}

[Install]
WantedBy=multi-user.target
