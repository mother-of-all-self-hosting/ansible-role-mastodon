TZ={{ mastodon_environment_variables_tz }}

{#
  See: https://raw.githubusercontent.com/mastodon/mastodon/refs/heads/main/.env.production.sample
#}

LOCAL_DOMAIN={{ mastodon_environment_variables_local_domain }}

SINGLE_USER_MODE={{ mastodon_environment_variables_single_user_mode | to_json }}

REDIS_HOST={{ mastodon_redis_hostname }}
REDIS_PORT={{ mastodon_redis_port }}
REDIS_USER={{ mastodon_redis_username }}
REDIS_PASSWORD={{ mastodon_redis_password }}

SECRET_KEY_BASE={{ mastodon_environment_variables_secret_key_base }}

{% if mastodon_environment_variables_otp_secret != '' %}
OTP_SECRET={{ mastodon_environment_variables_otp_secret }}
{% endif %}

ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY={{ mastodon_environment_variables_active_record_encryption_deterministic_key }}
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT={{ mastodon_environment_variables_active_record_encryption_key_derivation_salt }}
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY={{ mastodon_environment_variables_active_record_encryption_primary_key }}

VAPID_PRIVATE_KEY={{ mastodon_environment_variables_vapid_private_key }}
VAPID_PUBLIC_KEY={{ mastodon_environment_variables_vapid_public_key }}

RAILS_LOG_LEVEL={{ mastodon_environment_variables_rails_log_level }}
LOG_LEVEL={{ mastodon_environment_variables_log_level }}

NODE_ENV={{ mastodon_environment_variables_node_env }}

DB_HOST={{ mastodon_environment_variables_db_host }}
DB_PORT={{ mastodon_database_port }}
DB_USER={{ mastodon_database_username }}
DB_PASS={{ mastodon_database_password }}
DB_SSLMODE={{ mastodon_database_sslmode }}
DB_NAME={{ mastodon_database_name }}

SMTP_SERVER={{ mastodon_environment_variables_smtp_server }}
SMTP_PORT={{ mastodon_environment_variables_smtp_port }}
SMTP_LOGIN={{ mastodon_environment_variables_smtp_login }}
SMTP_PASSWORD={{ mastodon_environment_variables_smtp_password }}
SMTP_FROM_ADDRESS={{ mastodon_environment_variables_smtp_from_address }}
SMTP_ENABLE_STARTTLS={{ mastodon_environment_variables_smtp_enable_starttls }}

{{ mastodon_environment_variables_additional_variables }}
